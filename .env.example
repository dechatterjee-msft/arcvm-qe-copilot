# ─── Azure OpenAI Configuration ───────────────────────────────────────────────
# Set AZURE_OPENAI_ENABLED=true once you have all credentials configured.
AZURE_OPENAI_ENABLED=false

# Your Azure OpenAI resource endpoint (e.g. https://my-resource.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=

# API key from your Azure OpenAI resource
AZURE_OPENAI_API_KEY=

# API version (recommended: 2024-12-01-preview)
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ─── Model Deployments ────────────────────────────────────────────────────────
# Primary chat model deployment name
AZURE_OPENAI_DEPLOYMENT=

# Fast model for quick generation (defaults to primary if empty)
AZURE_OPENAI_DEPLOYMENT_FAST=

# Deep model for thorough generation (defaults to primary if empty)
AZURE_OPENAI_DEPLOYMENT_DEEP=

# Embedding model for retrieval and caching
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Enable ensemble (multi-model fanout) — true/false
AZURE_OPENAI_ADVISOR_ENSEMBLE_ENABLED=false

# ─── Embedding Cache ─────────────────────────────────────────────────────────
# SQLite path for cached embeddings (created automatically by bootstrap)
AZURE_OPENAI_EMBEDDING_DB_ENABLED=true
AZURE_OPENAI_EMBEDDING_DB_PATH=./data/embeddings.db

# ─── Azure DevOps (optional — for docs-driven planning from ADO repos) ──────
# AZDO_ORGANIZATION_URL=https://dev.azure.com/your-org
# AZDO_PROJECT=your-project
# AZDO_REPOSITORY=your-repo
# AZDO_FILE_PATH=/docs/README.md
# AZDO_BRANCH=main
# AZDO_PAT=your-personal-access-token

# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
AZURE_CONFIG_DIR=./.azure
REPORT_BASE_DIR=./artifacts/longevity
